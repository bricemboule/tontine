{
  "name": "tontineos",
  "version": "1.0.0",
  "private": true,
  "description": "TontineOS — Plateforme SaaS de gestion des tontines africaines",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "test:backend": "cd backend && .venv/bin/pytest -q",
    "test:backend:integration": "cd backend && TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/tontine_test .venv/bin/pytest -q",
    "db:up": "docker compose up -d postgres redis",
    "db:test:create": "docker compose exec postgres sh -c \"createdb -U postgres tontine_test || true\""
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.9.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.2"
  }
}
