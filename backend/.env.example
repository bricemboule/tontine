# TontineOS — Variables d'environnement
# Copier en .env et remplir les valeurs

# ── Général ──────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
API_BASE_URL=http://localhost:8000
GOOGLE_CLIENT_ID=

# ── Base de données ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/tontine_central

# ── Orange Money ─────────────────────────────────────────────
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_MERCHANT_KEY=
ORANGE_WEBHOOK_SECRET=

# ── MTN MoMo ──────────────────────────────────────────────────
MTN_API_KEY=
MTN_API_USER=
MTN_API_SECRET=
MTN_WEBHOOK_SECRET=

# ── Africa's Talking (SMS) ────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=

# ── Email SMTP ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tontineos.cm

# ── WhatsApp (Meta Business API) ─────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Stockage S3 / MinIO ───────────────────────────────────────
S3_BUCKET=tontineos
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
