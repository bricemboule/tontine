# ════════════════════════════════════════════════════════════════
# Production — copier en .env.production et remplir.
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# NE JAMAIS committer .env.production.
# ════════════════════════════════════════════════════════════════

# ── Domaine & TLS ───────────────────────────────────────────────
DOMAIN=app.exemple.cm
ACME_EMAIL=admin@exemple.cm

# ── Sécurité backend ────────────────────────────────────────────
# Générer : openssl rand -hex 32
SECRET_KEY=REMPLACER_par_openssl_rand_hex_32

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=tontine_central
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REMPLACER_mot_de_passe_fort

# ── Stockage objet (MinIO local — ou pointer un S3 externe) ─────
S3_BUCKET=tontineos
AWS_ACCESS_KEY_ID=REMPLACER_access_key
AWS_SECRET_ACCESS_KEY=REMPLACER_secret_key

# ── Authentification Google (optionnel) ─────────────────────────
GOOGLE_CLIENT_ID=

# ── Mobile Money — MTN (optionnel) ──────────────────────────────
MTN_API_KEY=
MTN_API_USER=
MTN_API_SECRET=
MTN_WEBHOOK_SECRET=

# ── Mobile Money — Orange (optionnel) ───────────────────────────
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_MERCHANT_KEY=
ORANGE_WEBHOOK_SECRET=

# ── SMS — Africa's Talking (optionnel) ──────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=

# ── Email SMTP (optionnel) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@exemple.cm
